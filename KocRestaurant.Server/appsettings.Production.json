{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Error"
    }
  },
  "AllowedHosts": "kocrestaurant.com;www.kocrestaurant.com",
  "ConnectionStrings": {
    "DefaultConnection": "Host=YOUR_PROD_DB_HOST;Port=5432;Database=KocRestaurantDb;Username=YOUR_PROD_DB_USER;Password=YOUR_PROD_DB_PASSWORD"
  },
  "CorsOrigins": [
    "https://kocrestaurant.com",
    "https://www.kocrestaurant.com",
    "http://kocrestaurant.com",
    "http://www.kocrestaurant.com"
  ],
  "JwtSettings": {
    "Secret": "ENTER_YOUR_SECURE_PRODUCTION_JWT_SECRET_KEY_HERE_MIN_32_CHARS",
    "Issuer": "KocRestaurant.Server",
    "Audience": "KocRestaurant.Client",
    "ExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  }
}
